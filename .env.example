# 치킨이닭 — 환경 변수 예시.
# 운영 시: `cp .env.example .env` 후 실제 값으로 교체. `.env`는 .gitignore 됨.
# 절대 .env 파일을 커밋하지 말 것.

# ── 실행 모드 ──
# 로컬 dev는 development, docker-compose는 environment에서 production으로 override.
NODE_ENV=production
PORT=3000

# ── 보안 ──
# 세션 쿠키 서명용 키 (32바이트 hex 권장).
# 생성: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=___CHANGE_ME___

# 관리자 PIN (6자리 숫자, ADR-024).
# 미지정 시 첫 부팅에 자동 생성되어 stdout에 1회 출력 — 즉시 .env에 옮겨둘 것.
DEFAULT_ADMIN_PIN=

# scripts/admin-add.js로 등록한 관리자 목록 (선택).
# 형식: [{"username":"admin","scrypt":"scrypt:<saltHex>:<hashHex>"}]
ADMIN_PINS=[]

# ── 운영 ──
# 자동 ZIP 스냅샷 주기 (분, ADR-022 변경: 30→120).
AUTO_SNAPSHOT_INTERVAL_MIN=120

# SQLite 파일 경로.
# - 로컬 dev: ./data/order.sqlite
# - Docker compose: /data/order.sqlite (named volume 마운트)
DB_PATH=/data/order.sqlite

# 데이터 디렉터리 (스냅샷 ZIP 등 부속 파일 저장 위치).
DATA_DIR=/data

# ── 관측 ──
# pino 로그 레벨 (trace/debug/info/warn/error/fatal).
LOG_LEVEL=info
