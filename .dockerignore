# Docker 빌드 컨텍스트에서 제외 — 이미지 슬림화 + 비밀 유출 방지.
# 핵심: .env / node_modules / dist는 항상 제외 (이미지 안에서 재생성).

# 의존성/빌드 산출물 — 이미지에서 다시 만든다
node_modules
dist

# VCS·CI·에디터
.git
.gitignore
.github
.gitattributes
.vscode
.idea

# Claude / 에이전트 메타데이터
.claude
.agents
skills-lock.json

# 문서·기획·테스트 산출물 — 운영 이미지 불필요
docs
tests
playwright.config.js
playwright-report
test-results
coverage
.vitest

# 로그·임시
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# 환경 파일 — 절대 이미지에 포함 X (compose의 env_file로 주입)
.env
.env.local
*.env.local
.env.example

# 원본 zip (디자인 번들)
comorder.zip
comorder_v2.zip

